---
interface Props {
  name:
    | 'github'
    | 'sun'
    | 'moon'
    | 'monitor'
    | 'copy'
    | 'sparkles'
    | 'layers'
    | 'image'
    | 'palette'
    | 'code'
    | 'compass'
    | 'presentation'
    | 'shield'
    | 'book'
    | 'arrow-up'
    | 'download'
    | 'link'
    | 'check-circle';
