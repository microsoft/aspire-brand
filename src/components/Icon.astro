---
interface Props {
  name: 'github' | 'sun' | 'moon' | 'monitor' | 'copy';
  size?: number | string;
  class?: string;
}

const { name, size = 18, class: className } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  class={className}
>
  {
    name === 'github' && (
      <path
        fill="currentColor"
        stroke="none"
        d="M12 1.25A10.75 10.75 0 0 0 8.6 22.2c.54.1.74-.23.74-.52v-1.83c-3.02.66-3.66-1.28-3.66-1.28-.5-1.23-1.2-1.56-1.2-1.56-.98-.67.08-.66.08-.66 1.08.08 1.65 1.1 1.65 1.1.96 1.63 2.52 1.16 3.13.88.1-.69.37-1.16.67-1.42-2.41-.27-4.95-1.19-4.95-5.3 0-1.17.43-2.13 1.12-2.88-.11-.28-.49-1.41.11-2.94 0 0 .92-.29 3.01 1.1a10.8 10.8 0 0 1 5.48 0c2.09-1.39 3-1.1 3-1.1.61 1.53.23 2.66.12 2.94.7.75 1.11 1.71 1.11 2.88 0 4.12-2.54 5.02-4.96 5.29.39.33.73.98.73 1.98v2.94c0 .29.2.63.75.52A10.75 10.75 0 0 0 12 1.25Z"
      />
    )
  }
  {name === 'sun' && (
    <>
      <circle cx="12" cy="12" r="4" />
      <path d="M12 2.5v2.25M12 19.25v2.25M21.5 12h-2.25M4.75 12H2.5M18.72 5.28l-1.59 1.59M6.87 17.13l-1.59 1.59M18.72 18.72l-1.59-1.59M6.87 6.87 5.28 5.28" />
    </>
  )}
  {name === 'moon' && (
    <path d="M20.25 14.25A8.25 8.25 0 0 1 9.75 3.75a8.25 8.25 0 1 0 10.5 10.5Z" />
  )}
  {name === 'monitor' && (
    <>
      <rect x="3.25" y="4.25" width="17.5" height="12.5" rx="2" />
      <path d="M8.5 20.25h7M12 16.75v3.5" />
    </>
  )}
  {name === 'copy' && (
    <>
      <rect x="9" y="9" width="10" height="10" rx="2" />
      <path d="M6 15H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v1" />
    </>
  )}
</svg>
