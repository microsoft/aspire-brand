---
import BrandLayout from '../layouts/BrandLayout.astro';
import CopyButton from '../components/CopyButton.astro';
import Icon from '../components/Icon.astro';

const basePath = import.meta.env.BASE_URL;
const repoUrl = 'https://github.com/microsoft/aspire-brand';
const deckPath = `${basePath}slides/intro/Aspire-Spring26-IntroDeck.pptx`;
const cssVarBlock = `:root {
  --aspire-color-primary: #7455dd;
  --aspire-color-purple: #512bd4;
  --aspire-color-secondary: #b9aaee;
  --aspire-color-muted: #dcd5f6;
  --aspire-color-grey: #dce0e8;
  --aspire-color-black: #1f1e33;
  --aspire-color-white: #ffffff;
}`;
const heroPalette = ['#7455DD', '#512BD4', '#B9AAEE', '#DCD5F6'];

const repositoryAreas = [
  {
    path: 'logo/',
    title: 'Official SVGs',
    description: 'Official Aspire logo files sized for brand surfaces, documentation, and presentations.',
  },
  {
    path: 'slides/',
    title: 'Presentation materials',
    description: 'The current Aspire intro deck for talks, demos, and community content.',
  },
  {
    path: 'src/',
    title: 'Astro site',
    description: 'A static reference site that keeps the guidance and downloadable assets together.',
  },
];

const logoAssets = [
  {
    title: 'Aspire logo (256)',
    description:
      'Primary large-format Aspire SVG for documentation, slides, and brand surfaces.',
    previewClass: 'asset-card__preview--light',
    asset: `${basePath}logo/aspire-logo-256.svg`,
    assetClass: 'asset-card__image asset-card__image--large',
    downloads: [{ label: 'Download SVG', href: `${basePath}logo/aspire-logo-256.svg` }],
  },
  {
    title: 'Aspire logo (32)',
    description:
      'Compact Aspire mark for smaller UI placements and tighter layouts.',
    previewClass: 'asset-card__preview--dark',
    asset: `${basePath}logo/aspire-logo-32.svg`,
    assetClass: 'asset-card__image asset-card__image--small',
    downloads: [{ label: 'Download SVG', href: `${basePath}logo/aspire-logo-32.svg` }],
  },
];

const colorScale = [
  {
    name: 'Aspire primary',
    token: '--aspire-color-primary',
    hex: '#7455DD',
    description: 'Primary accent token used across Aspire web experiences.',
  },
  {
    name: 'Aspire purple',
    token: '--aspire-color-purple',
    hex: '#512BD4',
    description: 'Darker companion purple used for gradients and hover states.',
  },
  {
    name: 'Aspire secondary',
    token: '--aspire-color-secondary',
    hex: '#B9AAEE',
    description: 'Soft supporting purple used in borders and secondary surfaces.',
  },
  {
    name: 'Aspire muted',
    token: '--aspire-color-muted',
    hex: '#DCD5F6',
    description: 'Light branded lavender used in subtle backgrounds and highlights.',
  },
  {
    name: 'Aspire grey',
    token: '--aspire-color-grey',
    hex: '#DCE0E8',
    description: 'Neutral light grey used in supporting surfaces and borders.',
  },
  {
    name: 'Aspire black',
    token: '--aspire-color-black',
    hex: '#1F1E33',
    description: 'Dark foundation color used for Aspire backgrounds and dark surfaces.',
  },
  {
    name: 'Aspire white',
    token: '--aspire-color-white',
    hex: '#FFFFFF',
    description: 'Foreground and surface white used throughout Aspire brand applications.',
  },
];

const guidance = [
  {
    title: 'Name the product Aspire',
    description: 'Always refer to the product as Aspire. Do not call it ".NET Aspire" in brand or marketing materials.',
  },
  {
    title: 'Use aspire.dev for docs and content',
    description: 'Point people to aspire.dev for official documentation, product content, and messaging updates.',
  },
  {
    title: 'Use the official logo files',
    description: 'Do not redraw, stretch, crop, outline, or otherwise reshape the Aspire mark.',
  },
  {
    title: 'Keep the fills and palette intact',
    description: 'Retain the multitone fills and use the published Aspire palette when pairing the logo with web, deck, or event materials.',
  },
  {
    title: 'Validate in multiple themes',
    description: 'Preview assets in light, dark, and system themes so contrast and legibility stay strong in every environment.',
  },
];
---

<BrandLayout
  title="Aspire Brand Assets"
  description="Official Aspire logos, color references, usage guidance, and presentation materials."
>
  <main class="page">
    <section class="hero">
      <div class="hero__copy">
        <p class="eyebrow eyebrow--icon">
          <Icon name="sparkles" size={14} />
          <span>Aspire brand</span>
        </p>
        <h1>Official logos, colors, and presentation assets for Aspire.</h1>
        <p class="lede">
          A consumer-facing brand guide with curated SVG downloads, practical usage guidance, and a theme-aware Astro
          site for reviewing Aspire assets in light, dark, or system mode.
        </p>
        <div class="actions">
          <a class="button" href="#logos">Browse logos</a>
          <a class="button button--secondary" href="#colors">View palette</a>
          <a class="button button--ghost" href={repoUrl} rel="noreferrer" target="_blank">
            <Icon name="github" size={16} />
            <span>Open repo</span>
          </a>
        </div>
      </div>

      <div class="hero__visual" aria-hidden="true">
        <div class="hero-frame hero-frame--primary">
          <img src={`${basePath}logo/aspire-logo-256.svg`} alt="" class="hero-frame__image hero-frame__image--primary" />
        </div>

        <div class="hero-panel">
          <p class="hero-panel__label">Preview themes</p>
          <div class="hero-panel__chips">
            <span class="hero-panel__chip">Light</span>
            <span class="hero-panel__chip">Dark</span>
            <span class="hero-panel__chip">System</span>
          </div>
          <div class="hero-panel__swatches">
            {heroPalette.map((swatch) => (
              <span class="hero-panel__swatch" style={`background:${swatch}`}></span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section section--split" id="about">
      <div>
        <div class="section__header">
          <p class="eyebrow eyebrow--icon">
            <Icon name="layers" size={14} />
            <span>Approach</span>
          </p>
          <h2>Keep the repo asset-first and easy to consume.</h2>
          <p>
            This repository stays intentionally focused on the pieces most people need to create on-brand Aspire
            materials: official logos, approved colors, practical naming and content guidance, and the current intro
            deck.
          </p>
        </div>

        <div class="note-card">
          <h3>General guidance</h3>
          <p>
            Use this site for brand assets and styling references, and rely on <a href="https://aspire.dev">aspire.dev</a>
            whenever you need official product docs, messaging, or supporting content.
          </p>
        </div>
      </div>

      <div class="repo-grid">
        {repositoryAreas.map((area) => (
          <article class="repo-card">
            <p class="repo-card__path">{area.path}</p>
            <h3>{area.title}</h3>
            <p>{area.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="logos">
      <div class="section__header">
        <p class="eyebrow eyebrow--icon">
          <Icon name="image" size={14} />
          <span>Logos</span>
        </p>
        <h2>Official SVG files for reuse.</h2>
        <p>
          Download the current Aspire brand assets directly from the repository-backed site. These are the public logo
          files intended for reuse in decks, docs, web pages, and event materials.
        </p>
      </div>

      <div class="asset-grid">
        {logoAssets.map((logo) => (
          <article class="asset-card">
            <div class={`asset-card__preview ${logo.previewClass}`} aria-hidden="true">
              <img src={logo.asset} alt="" class={logo.assetClass} />
            </div>

            <div class="asset-card__body">
              <div class="stack">
                <h3>{logo.title}</h3>
                <p>{logo.description}</p>
              </div>

              <div class="link-row">
                {logo.downloads.map((download) => (
                  <a class="pill-link" href={download.href} download>
                    {download.label}
                  </a>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="colors">
      <div class="section__header">
        <p class="eyebrow eyebrow--icon">
          <Icon name="palette" size={14} />
          <span>Colors</span>
        </p>
        <h2>The current Aspire palette.</h2>
        <p>
          Use these values when you need official Aspire color references for websites, presentations, and supporting
          collateral.
        </p>
      </div>

      <div class="color-grid">
        {colorScale.map((color) => (
          <article class="color-card">
            <div class="swatch" style={`background:${color.hex}`}></div>
            <div class="stack">
              <h3>{color.name}</h3>
              <p>{color.description}</p>
            </div>
            <div class="color-card__footer">
              <div class="color-card__actions">
                <span class="color-card__hex">{color.hex}</span>
                <CopyButton value={color.hex} label="Copy" />
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="css-vars">
      <div class="section__header">
        <p class="eyebrow eyebrow--icon">
          <Icon name="code" size={14} />
          <span>CSS variables</span>
        </p>
        <h2>Use official tokens in your styles.</h2>
        <p>
          If you need to theme a web experience or a demo site, start with the published Aspire color variables below.
        </p>
      </div>

      <article class="code-card">
        <div class="code-card__header">
          <div class="stack">
            <h3>Aspire brand variables</h3>
            <p>Copy the full token block for quick reuse in CSS.</p>
          </div>
          <CopyButton value={cssVarBlock} label="Copy CSS vars" />
        </div>
        <pre class="code-block"><code>{cssVarBlock}</code></pre>
      </article>
    </section>

    <section class="section" id="guidance">
      <div class="section__header">
        <p class="eyebrow eyebrow--icon">
          <Icon name="compass" size={14} />
          <span>Guidance</span>
        </p>
        <h2>Simple rules that keep Aspire recognizable.</h2>
      </div>

      <div class="guidance-grid">
        {guidance.map((item) => (
          <article class="guidance-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="slides">
      <div class="section__header">
        <p class="eyebrow eyebrow--icon">
          <Icon name="presentation" size={14} />
          <span>Presentation materials</span>
        </p>
        <h2>The current intro deck is part of the brand repository too.</h2>
      </div>

      <article class="download-card">
        <h3>Aspire Spring 2026 intro deck</h3>
        <p>
          Use the current presentation deck as a starting point for talks, demos, and community sessions about
          Aspire.
        </p>
        <p class="download-card__meta">PowerPoint (.pptx)</p>
        <div class="link-row">
          <a class="pill-link" href={deckPath} download>
            Download deck
          </a>
        </div>
      </article>
    </section>

    <section class="section" id="license">
      <article class="license-card">
        <p class="eyebrow eyebrow--icon">
          <Icon name="shield" size={14} />
          <span>License</span>
        </p>
        <h2>CC0 for artwork, trademark protections remain in place.</h2>
        <p>
          The artwork in this repository is released under CC0 1.0 so it can be reused broadly in community decks,
          blog posts, and other Aspire-related content. Trademark rights are not waived; the Aspire name and logo
          remain subject to Microsoft&apos;s trademark rights and brand review expectations.
        </p>
        <div class="link-row">
          <a class="pill-link" href={`${basePath}LICENSE`} download>Read the license</a>
          <a class="pill-link" href={repoUrl} rel="noreferrer" target="_blank">View repository</a>
        </div>
      </article>
    </section>
  </main>
</BrandLayout>
