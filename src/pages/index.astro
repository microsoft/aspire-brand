---
import BrandLayout from '../layouts/BrandLayout.astro';

const basePath = import.meta.env.BASE_URL;
const repoUrl = 'https://github.com/microsoft/aspire-brand';
const deckPath = `${basePath}slides/intro/Aspire-Spring26-IntroDeck.pptx`;

const repositoryAreas = [
  {
    path: 'logo/',
    title: 'Official SVGs',
    description: 'A small set of official Aspire logo files copied directly from the aspire.dev frontend assets.',
  },
  {
    path: 'slides/',
    title: 'Presentation materials',
    description: 'The current Aspire intro deck for talks, demos, and community content.',
  },
  {
    path: 'src/',
    title: 'Astro site',
    description: 'A static reference site that keeps the guidance and downloadable assets together.',
  },
];

const logoAssets = [
  {
    title: 'Aspire logo (256)',
    description:
      'Primary large-format Aspire SVG copied from aspire.dev for documentation, slides, and brand surfaces.',
    previewClass: 'asset-card__preview--light',
    asset: `${basePath}logo/aspire-logo-256.svg`,
    assetClass: 'asset-card__image asset-card__image--large',
    sourcePath: 'src/frontend/src/assets/aspire-logo-256.svg',
    downloads: [{ label: 'Download SVG', href: `${basePath}logo/aspire-logo-256.svg` }],
  },
  {
    title: 'Aspire logo (32)',
    description:
      'Compact Aspire mark used by the official site for smaller UI placements and tighter layouts.',
    previewClass: 'asset-card__preview--dark',
    asset: `${basePath}logo/aspire-logo-32.svg`,
    assetClass: 'asset-card__image asset-card__image--small',
    sourcePath: 'src/frontend/src/assets/aspire-logo-32.svg',
    downloads: [{ label: 'Download SVG', href: `${basePath}logo/aspire-logo-32.svg` }],
  },
  {
    title: 'Aspire favicon',
    description:
      'Site icon SVG copied from the public Aspire frontend and suitable for browser or navigation icon usage.',
    previewClass: 'asset-card__preview--neutral',
    asset: `${basePath}logo/favicon.svg`,
    assetClass: 'asset-card__image asset-card__image--small',
    sourcePath: 'public/favicon.svg',
    downloads: [{ label: 'Download SVG', href: `${basePath}logo/favicon.svg` }],
  },
];

const colorScale = [
  {
    name: 'Aspire primary',
    token: '--aspire-color-primary',
    hex: '#7455DD',
    description: 'Primary accent token used by the Aspire frontend theme.',
  },
  {
    name: 'Aspire purple',
    token: '--aspire-color-purple',
    hex: '#512BD4',
    description: 'Darker companion purple used for gradients and hover states.',
  },
  {
    name: 'Aspire secondary',
    token: '--aspire-color-secondary',
    hex: '#B9AAEE',
    description: 'Soft supporting purple used in borders and secondary surfaces.',
  },
  {
    name: 'Aspire muted',
    token: '--aspire-color-muted',
    hex: '#DCD5F6',
    description: 'Light branded lavender used in subtle backgrounds and highlights.',
  },
  {
    name: 'Aspire grey',
    token: '--aspire-color-grey',
    hex: '#DCE0E8',
    description: 'Neutral light grey from the official Aspire site theme.',
  },
  {
    name: 'Aspire black',
    token: '--aspire-color-black',
    hex: '#1F1E33',
    description: 'Dark foundation color used as the main site background in the Aspire frontend.',
  },
  {
    name: 'Aspire white',
    token: '--aspire-color-white',
    hex: '#FFFFFF',
    description: 'Foreground and surface white used throughout the frontend theme.',
  },
];

const guidance = [
  {
    title: 'Use the official source files',
    description: 'Prefer the SVGs copied from aspire.dev rather than recreating or tracing the logo.',
  },
  {
    title: 'Preserve proportions',
    description: 'Do not stretch, crop, redraw, outline, or otherwise reshape the Aspire mark.',
  },
  {
    title: 'Keep the fills intact',
    description: 'Retain the existing multitone fills and use the official palette values when pairing the logo with site or deck styling.',
  },
  {
    title: 'Avoid unofficial variants',
    description: 'Do not introduce alternate wordmarks, composite lockups, or icon treatments that are not part of the published asset set.',
  },
];
---

<BrandLayout
  title="Aspire Brand Assets"
  description="Official Aspire logos, color references, usage guidance, and presentation materials."
>
  <main class="page">
    <section class="hero">
      <div class="hero__copy">
        <p class="eyebrow">Aspire brand</p>
        <h1>Official logos, colors, and presentation assets for Aspire.</h1>
        <p class="lede">
          A lightweight brand repository with curated SVG downloads, practical usage guidance, and an Astro site
          built from the official Aspire frontend asset set.
        </p>
        <div class="actions">
          <a class="button" href="#logos">Browse logos</a>
          <a class="button button--secondary" href="#colors">View palette</a>
          <a class="button button--ghost" href={repoUrl} rel="noreferrer" target="_blank">Open repo</a>
        </div>
      </div>

      <div class="hero__visual" aria-hidden="true">
        <div class="hero-frame hero-frame--primary">
          <img src={`${basePath}logo/aspire-logo-256.svg`} alt="" class="hero-frame__image hero-frame__image--primary" />
        </div>

        <div class="hero-frame hero-frame--compact">
          <img src={`${basePath}logo/aspire-logo-32.svg`} alt="" class="hero-frame__image hero-frame__image--compact" />
        </div>

        <div class="hero-note">
          <span>Source of truth</span>
          <strong>aspire.dev/src/frontend</strong>
        </div>
      </div>
    </section>

    <section class="section section--split" id="about">
      <div>
        <div class="section__header">
          <p class="eyebrow">Approach</p>
          <h2>Keep the repo asset-first and easy to consume.</h2>
          <p>
            This repository now mirrors the official Aspire frontend assets instead of introducing alternate logo
            treatments. The scope stays intentionally small: official SVGs, the current site palette, practical usage
            guidance, and the current intro deck.
          </p>
        </div>

        <div class="note-card">
          <h3>Source of truth</h3>
          <p>
            Logos come from <code>aspire.dev/src/frontend/src/assets</code> and <code>aspire.dev/src/frontend/public</code>.
            Theme colors come from <code>aspire.dev/src/frontend/src/styles/site.css</code>.
          </p>
        </div>
      </div>

      <div class="repo-grid">
        {repositoryAreas.map((area) => (
          <article class="repo-card">
            <p class="repo-card__path">{area.path}</p>
            <h3>{area.title}</h3>
            <p>{area.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="logos">
      <div class="section__header">
        <p class="eyebrow">Logos</p>
        <h2>Official SVG files for reuse.</h2>
        <p>
          Download the current Aspire brand assets directly from the repository-backed site. These files are copied
          from the official Aspire frontend and published here in a simpler asset library.
        </p>
      </div>

      <div class="asset-grid">
        {logoAssets.map((logo) => (
          <article class="asset-card">
            <div class={`asset-card__preview ${logo.previewClass}`} aria-hidden="true">
              <img src={logo.asset} alt="" class={logo.assetClass} />
            </div>

            <div class="asset-card__body">
              <div class="stack">
                <h3>{logo.title}</h3>
                <p>{logo.description}</p>
                <p class="meta-text">
                  Source: <code>{logo.sourcePath}</code>
                </p>
              </div>

              <div class="link-row">
                {logo.downloads.map((download) => (
                  <a class="pill-link" href={download.href} download>
                    {download.label}
                  </a>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="colors">
      <div class="section__header">
        <p class="eyebrow">Colors</p>
        <h2>The current Aspire frontend palette.</h2>
        <p>
          These color references are taken from the official frontend theme in <code>aspire.dev/src/frontend/src/styles/site.css</code>.
        </p>
      </div>

      <div class="color-grid">
        {colorScale.map((color) => (
          <article class="color-card">
            <div class="swatch" style={`background:${color.hex}`}></div>
            <h3>{color.name}</h3>
            <p>{color.description}</p>
            <p class="meta-text">{color.token}</p>
            <span class="color-card__hex">{color.hex}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="guidance">
      <div class="section__header">
        <p class="eyebrow">Guidance</p>
        <h2>Simple rules that keep Aspire recognizable.</h2>
      </div>

      <div class="guidance-grid">
        {guidance.map((item) => (
          <article class="guidance-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="slides">
      <div class="section__header">
        <p class="eyebrow">Presentation materials</p>
        <h2>The current intro deck is part of the brand repository too.</h2>
      </div>

      <article class="download-card">
        <h3>Aspire Spring 2026 intro deck</h3>
        <p>
          Use the current presentation deck as a starting point for talks, demos, and community sessions about
          Aspire.
        </p>
        <p class="download-card__meta">PowerPoint (.pptx)</p>
        <div class="link-row">
          <a class="pill-link" href={deckPath} download>
            Download deck
          </a>
        </div>
      </article>
    </section>

    <section class="section" id="license">
      <article class="license-card">
        <p class="eyebrow">License</p>
        <h2>CC0 for artwork, trademark protections remain in place.</h2>
        <p>
          The artwork in this repository is released under CC0 1.0 so it can be reused broadly in community decks,
          blog posts, and other Aspire-related content. Trademark rights are not waived; the Aspire name and logo
          remain subject to Microsoft&apos;s trademark rights and brand review expectations.
        </p>
        <div class="link-row">
          <a class="pill-link" href={`${basePath}LICENSE`} download>Read the license</a>
          <a class="pill-link" href={repoUrl} rel="noreferrer" target="_blank">View repository</a>
        </div>
      </article>
    </section>
  </main>
</BrandLayout>
