---
import BrandLayout from '../layouts/BrandLayout.astro';
import CopyButton from '../components/CopyButton.astro';
import Icon from '../components/Icon.astro';

const basePath = import.meta.env.BASE_URL;
const repoUrl = 'https://github.com/microsoft/aspire-brand';
const deckPath = `${basePath}slides/intro/Aspire-Spring26-IntroDeck.pptx`;
const cssVarBlock = `:root {
  --aspire-color-primary: #7455dd;
  --aspire-color-purple: #512bd4;
  --aspire-color-secondary: #b9aaee;
  --aspire-color-muted: #dcd5f6;
  --aspire-color-grey: #dce0e8;
  --aspire-color-black: #1f1e33;
  --aspire-color-white: #ffffff;
}`;
const quickLinks = [
  { href: '#logos', icon: 'image' as const, label: 'Logos' },
  { href: '#colors', icon: 'palette' as const, label: 'Colors' },
  { href: '#guidance', icon: 'compass' as const, label: 'Guidance' },
  { href: '#slides', icon: 'presentation' as const, label: 'Slides' },
];

const repositoryAreas = [
  {
    label: 'Logos',
    title: 'Official marks',
    description: 'Ready-to-use SVG logos for docs, decks, websites, and event materials.',
  },
  {
    label: 'Colors',
    title: 'Core palette',
    description: 'The key Aspire colors you need for interfaces, visuals, and supporting brand work.',
  },
  {
    label: 'Slides',
    title: 'Presentation deck',
    description: 'A current deck you can start from for talks, demos, and community sessions.',
  },
];

const logoAssets = [
  {
    title: 'Aspire logo (256)',
    description:
      'Best for slides, docs, hero placements, and larger brand moments.',
    previewClass: 'asset-card__preview--light',
    asset: `${basePath}logo/aspire-logo-256.svg`,
    assetClass: 'asset-card__image asset-card__image--large',
    downloads: [{ label: 'Download SVG', href: `${basePath}logo/aspire-logo-256.svg` }],
  },
  {
    title: 'Aspire logo (32)',
    description:
      'Best for tighter UI placements or places where the mark needs to stay compact.',
    previewClass: 'asset-card__preview--dark',
    asset: `${basePath}logo/aspire-logo-32.svg`,
    assetClass: 'asset-card__image asset-card__image--small',
    downloads: [{ label: 'Download SVG', href: `${basePath}logo/aspire-logo-32.svg` }],
  },
];

const colorScale = [
  {
    name: 'Aspire primary',
    token: '--aspire-color-primary',
    hex: '#7455DD',
    description: 'Primary brand accent.',
  },
  {
    name: 'Aspire purple',
    token: '--aspire-color-purple',
    hex: '#512BD4',
    description: 'Stronger companion purple for depth and emphasis.',
  },
  {
    name: 'Aspire secondary',
    token: '--aspire-color-secondary',
    hex: '#B9AAEE',
    description: 'Soft supporting purple for accents and surfaces.',
  },
  {
    name: 'Aspire muted',
    token: '--aspire-color-muted',
    hex: '#DCD5F6',
    description: 'Light lavender for subtle fills and backgrounds.',
  },
  {
    name: 'Aspire grey',
    token: '--aspire-color-grey',
    hex: '#DCE0E8',
    description: 'Neutral support color for quiet surfaces and separators.',
  },
  {
    name: 'Aspire black',
    token: '--aspire-color-black',
    hex: '#1F1E33',
    description: 'Dark anchor color for dark themes and contrast.',
  },
  {
    name: 'Aspire white',
    token: '--aspire-color-white',
    hex: '#FFFFFF',
    description: 'Clean base for light surfaces and negative space.',
  },
];

const guidance = [
  {
    title: 'Say Aspire',
    description: 'Use Aspire in brand and marketing copy. Avoid calling the product ".NET Aspire".',
  },
  {
    title: 'Send people to aspire.dev',
    description: 'Use aspire.dev for official docs, product info, and supporting content.',
  },
  {
    title: 'Use the provided marks',
    description: 'Do not redraw, stretch, crop, outline, or otherwise reshape the Aspire logo.',
  },
  {
    title: 'Keep the palette relationships intact',
    description: 'Use the core colors as provided so Aspire stays recognizable across surfaces.',
  },
  {
    title: 'Check light and dark surfaces',
    description: 'Make sure the logo stays crisp, readable, and balanced wherever it appears.',
  },
];
---

<BrandLayout
  title="Aspire Brand Assets"
  description="Official Aspire logos, color references, usage guidance, and presentation materials."
>
  <main class="page">
    <section class="hero">
      <div class="hero__copy">
        <p class="eyebrow eyebrow--icon">
          <Icon name="sparkles" size={16} />
          <span>Aspire brand</span>
        </p>
        <h1>Use the Aspire brand clearly and consistently.</h1>
        <p class="lede">
          Find the official logos, core color references, naming guidance, and presentation material you need to put
          Aspire in front of people with confidence.
        </p>
        <div class="actions">
          <a class="button" href="#logos">Get logos</a>
          <a class="button button--secondary" href="#colors">See colors</a>
          <a class="button button--ghost" href={repoUrl} rel="noreferrer" target="_blank">
            <Icon name="github" size={16} />
            <span>Open GitHub</span>
          </a>
        </div>

        <nav class="section-nav" aria-label="Jump to section">
          {quickLinks.map((link) => (
            <a class="section-nav__link" href={link.href}>
              <Icon name={link.icon} size={16} />
              <span>{link.label}</span>
            </a>
          ))}
        </nav>
      </div>

      <div class="hero__visual" aria-hidden="true">
        <div class="hero-frame hero-frame--primary" data-parallax data-parallax-speed="0.08">
          <img src={`${basePath}logo/aspire-logo-256.svg`} alt="" class="hero-frame__image hero-frame__image--primary" />
        </div>
      </div>
    </section>

    <section class="section section--split" id="about">
      <div>
        <div class="section__header">
          <p class="eyebrow eyebrow--icon">
            <Icon name="layers" size={16} />
            <span>What&apos;s here</span>
          </p>
          <h2>A focused brand kit for everyday use.</h2>
          <p>
            Everything here is meant to help you move quickly: the official marks, the core colors, a short set of
            naming rules, and a current presentation deck.
          </p>
        </div>

        <div class="note-card">
          <h3>Start here</h3>
          <p>
            Use this page for brand assets and visual guidance. When you need product docs, the product story, or
            supporting content, send people to <a href="https://aspire.dev">aspire.dev</a>.
          </p>
        </div>
      </div>

      <div class="repo-grid">
        {repositoryAreas.map((area) => (
          <article class="repo-card">
            <p class="repo-card__path">{area.label}</p>
            <h3>{area.title}</h3>
            <p>{area.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="logos">
      <div class="section__header">
        <p class="eyebrow eyebrow--icon">
          <Icon name="image" size={16} />
          <span>Logos</span>
        </p>
        <h2>Use the official Aspire marks.</h2>
        <p>
          Choose the size that best fits the space, then keep the shape and color relationships intact.
        </p>
      </div>

      <div class="asset-grid">
        {logoAssets.map((logo) => (
          <article class="asset-card">
            <div class={`asset-card__preview ${logo.previewClass}`} aria-hidden="true">
              <img src={logo.asset} alt="" class={logo.assetClass} />
            </div>

            <div class="asset-card__body">
              <div class="stack">
                <h3>{logo.title}</h3>
                <p>{logo.description}</p>
              </div>

              <div class="link-row">
                {logo.downloads.map((download) => (
                  <a class="pill-link" href={download.href} download>
                    {download.label}
                  </a>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="colors">
      <div class="section__header">
        <p class="eyebrow eyebrow--icon">
          <Icon name="palette" size={16} />
          <span>Colors</span>
        </p>
        <h2>Core Aspire colors.</h2>
        <p>
          Use these values when you need brand-aligned color in decks, sites, demos, or supporting visuals.
        </p>
      </div>

      <div class="color-grid">
        {colorScale.map((color) => (
          <article class="color-card">
            <div class="swatch" style={`background:${color.hex}`}></div>
            <div class="stack">
              <h3>{color.name}</h3>
              <p>{color.description}</p>
            </div>
            <div class="color-card__footer">
              <div class="color-card__actions">
                <span class="color-card__hex">{color.hex}</span>
                <CopyButton value={color.hex} label="Copy" />
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="css-vars">
      <div class="section__header">
        <p class="eyebrow eyebrow--icon">
          <Icon name="code" size={16} />
          <span>CSS variables</span>
        </p>
        <h2>Ready-to-use color tokens.</h2>
        <p>
          If you&apos;re styling a web experience or demo, start with these tokens.
        </p>
      </div>

      <article class="code-card">
        <div class="code-card__header">
          <div class="stack">
            <h3>Aspire CSS variables</h3>
            <p>Use this block as a starting point for implementation.</p>
          </div>
          <CopyButton value={cssVarBlock} label="Copy CSS vars" />
        </div>
        <pre class="code-block"><code>{cssVarBlock}</code></pre>
      </article>
    </section>

    <section class="section" id="guidance">
      <div class="section__header">
        <p class="eyebrow eyebrow--icon">
          <Icon name="compass" size={16} />
          <span>Guidance</span>
        </p>
        <h2>A few simple rules go a long way.</h2>
      </div>

      <div class="guidance-grid">
        {guidance.map((item) => (
          <article class="guidance-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="slides">
      <div class="section__header">
        <p class="eyebrow eyebrow--icon">
          <Icon name="presentation" size={16} />
          <span>Presentation materials</span>
        </p>
        <h2>Start from the current deck.</h2>
      </div>

      <article class="download-card">
        <h3>Aspire Spring 2026 intro deck</h3>
        <p>
          Use the current deck as a starting point for talks, demos, and community sessions about Aspire.
        </p>
        <p class="download-card__meta">PowerPoint (.pptx)</p>
        <div class="link-row">
          <a class="pill-link" href={deckPath} download>
            Download deck
          </a>
        </div>
      </article>
    </section>

    <section class="section" id="license">
      <article class="license-card">
        <p class="eyebrow eyebrow--icon">
          <Icon name="shield" size={16} />
          <span>License</span>
        </p>
        <h2>Use the artwork broadly. Respect the trademark.</h2>
        <p>
          The artwork in this brand kit is released under CC0 1.0 for broad reuse in decks, blog posts, and other
          Aspire-related content. Trademark rights are not waived; the Aspire name and logo remain subject to
          Microsoft&apos;s trademark rights and brand review expectations.
        </p>
        <div class="link-row">
          <a class="pill-link" href={`${basePath}LICENSE`} download>Read the license</a>
          <a class="pill-link" href={repoUrl} rel="noreferrer" target="_blank">View on GitHub</a>
        </div>
      </article>
    </section>
  </main>
</BrandLayout>
