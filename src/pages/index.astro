---
import { Code } from 'astro-expressive-code/components';
import BrandLayout from '../layouts/BrandLayout.astro';
import CopyButton from '../components/CopyButton.astro';
import Icon from '../components/Icon.astro';
import SectionHeading from '../components/SectionHeading.astro';

const basePath = import.meta.env.BASE_URL;
const repoUrl = 'https://github.com/microsoft/aspire-brand';
const deckPath = `${basePath}slides/intro/Aspire-Spring26-IntroDeck.pptx`;
const cssVarBlock = `:root {
  --aspire-color-primary: #7455dd;
  --aspire-color-purple: #512bd4;
  --aspire-color-secondary: #b9aaee;
  --aspire-color-muted: #dcd5f6;
  --aspire-color-grey: #dce0e8;
  --aspire-color-black: #1f1e33;
  --aspire-color-white: #ffffff;
  --aspire-accent-magenta: #b30f87;
  --aspire-accent-flamingo: #f65163;
  --aspire-accent-blue: #0078d7;
  --aspire-accent-cyan: #0b7e84;
  --aspire-accent-yellow: #9b8308;
  --aspire-gradient-purple-magenta: linear-gradient(90deg, #7455dd 0%, #b30f87 100%);
  --aspire-gradient-blue-purple: linear-gradient(90deg, #0078d7 0%, #7455dd 100%);
  --aspire-gradient-flamingo-purple: linear-gradient(90deg, #f65163 0%, #7455dd 100%);
  --aspire-gradient-purple-cyan: linear-gradient(90deg, #7455dd 0%, #0b7e84 100%);
}`;
const quickLinks = [
  { href: '#logos', icon: 'image' as const, label: 'Logos' },
  { href: '#colors', icon: 'palette' as const, label: 'Colors' },
  { href: '#guidance', icon: 'compass' as const, label: 'Guidance' },
  { href: '#slides', icon: 'presentation' as const, label: 'Slides' },
];

const featureHighlights = [
  {
    icon: 'image' as const,
    title: 'Official marks',
    description: 'SVG logo downloads for both focal placements and tighter interface moments.',
  },
  {
    icon: 'palette' as const,
    title: 'Core and supporting color',
    description: 'The core purple-led palette, plus expressive accents and gradients for standout moments.',
  },
  {
    icon: 'presentation' as const,
    title: 'Presentation starter',
    description: 'A current deck you can adapt for talks, demos, workshops, and community sessions.',
  },
];

const logoAssets = [
  {
    title: 'Aspire logo (256)',
    description:
     'Best for slides, docs, hero placements, and larger brand moments.',
    previewClass: 'asset-card__preview--light',
    asset: `${basePath}logo/aspire-logo-256.svg`,
    assetClass: 'asset-card__image asset-card__image--large',
    downloads: [{ label: 'Download SVG', href: `${basePath}logo/aspire-logo-256.svg`, icon: 'download' as const }],
  },
  {
    title: 'Aspire logo (32)',
    description:
     'Best for tighter UI placements or places where the mark needs to stay compact.',
    previewClass: 'asset-card__preview--dark',
    asset: `${basePath}logo/aspire-logo-32.svg`,
    assetClass: 'asset-card__image asset-card__image--small',
    downloads: [{ label: 'Download SVG', href: `${basePath}logo/aspire-logo-32.svg`, icon: 'download' as const }],
  },
];

const colorScale = [
  {
    name: 'Aspire primary',
    token: '--aspire-color-primary',
    hex: '#7455DD',
    description: 'Primary brand accent.',
  },
  {
    name: 'Aspire purple',
    token: '--aspire-color-purple',
    hex: '#512BD4',
    description: 'Stronger companion purple for depth and emphasis.',
  },
  {
    name: 'Aspire secondary',
    token: '--aspire-color-secondary',
    hex: '#B9AAEE',
    description: 'Soft supporting purple for accents and surfaces.',
  },
  {
    name: 'Aspire muted',
    token: '--aspire-color-muted',
    hex: '#DCD5F6',
    description: 'Light lavender for subtle fills and backgrounds.',
  },
  {
    name: 'Aspire grey',
    token: '--aspire-color-grey',
    hex: '#DCE0E8',
    description: 'Neutral support color for quiet surfaces and separators.',
  },
  {
    name: 'Aspire black',
    token: '--aspire-color-black',
    hex: '#1F1E33',
    description: 'Dark anchor color for dark themes and contrast.',
  },
  {
    name: 'Aspire white',
    token: '--aspire-color-white',
    hex: '#FFFFFF',
    description: 'Clean base for light surfaces and negative space.',
  },
];

const supportingAccents = [
  {
    name: 'Accent magenta',
    hex: '#B30F87',
  },
  {
    name: 'Accent flamingo',
    hex: '#F65163',
  },
  {
    name: 'Accent blue',
    hex: '#0078D7',
  },
  {
    name: 'Accent cyan',
    hex: '#0B7E84',
  },
  {
    name: 'Accent yellow',
    hex: '#9B8308',
  },
];

const gradients = [
  {
    name: 'Purple to magenta',
    value: 'linear-gradient(90deg, #7455DD 0%, #B30F87 100%)',
    guidance: 'Use for hero accents, highlights, or editorial-style flourishes.',
  },
  {
    name: 'Blue to purple',
    value: 'linear-gradient(90deg, #0078D7 0%, #7455DD 100%)',
    guidance: 'Works well for product-led visuals, diagrams, and directional emphasis.',
  },
  {
    name: 'Flamingo to purple',
    value: 'linear-gradient(90deg, #F65163 0%, #7455DD 100%)',
    guidance: 'Bring in warmer energy for campaign moments and bold callouts.',
  },
  {
    name: 'Purple to cyan',
    value: 'linear-gradient(90deg, #7455DD 0%, #0B7E84 100%)',
    guidance: 'Use sparingly when the layout needs a cleaner, more technical accent.',
  },
];

const guidanceDos = [
  'Call the product Aspire in brand, editorial, and marketing copy.',
  'Use aspire.dev when you need official docs, product explanation, or supporting content.',
  'Use the supplied SVG files without redrawing, outlining, or reshaping the mark.',
  'Give the logo breathing room and choose high-contrast surfaces that keep it crisp.',
  'Keep the tone clear, helpful, direct, and approachable.',
  'Let the core purple system lead and use accent colors or gradients as supporting expression.',
];

const guidanceDonts = [
  'Do not call the product ".NET Aspire" in consumer-facing brand or marketing content.',
  'Do not stretch, rotate, recolor, or crowd the logo with partner marks, badges, or dense UI.',
  'Do not make gradients or supporting accents carry the whole interface on their own.',
  'Do not rely on internal shorthand when a simple reader-facing explanation would be clearer.',
];
---

<BrandLayout
  title="Aspire Brand Assets"
  description="Official Aspire logos, color references, usage guidance, and presentation materials."
>
  <main class="page">
    <section class="hero">
      <div class="hero__copy">
        <p class="eyebrow eyebrow--icon">
          <Icon name="sparkles" size={16} />
          <span>Aspire brand</span>
        </p>
        <h1>Use the Aspire brand clearly and consistently.</h1>
        <p class="lede">
          Find the official logos, core color references, naming guidance, and presentation material you need to put
          Aspire in front of people with confidence.
        </p>
        <div class="actions">
          <a class="button button--jump" href="#logos">
            <Icon name="image" size={18} />
            <span>Browse logos</span>
          </a>
          <a class="button button--secondary button--jump" href="#colors">
            <Icon name="palette" size={18} />
            <span>Explore colors</span>
          </a>
          <a class="button button--ghost" href={repoUrl} rel="noreferrer" target="_blank">
            <Icon name="github" size={16} />
            <span>View GitHub</span>
          </a>
        </div>

        <nav class="section-nav" aria-label="Jump to section">
          {quickLinks.map((link) => (
            <a class="section-nav__link" href={link.href}>
              <Icon name={link.icon} size={16} />
              <span>{link.label}</span>
            </a>
          ))}
        </nav>
      </div>

      <div class="hero__visual" aria-hidden="true">
        <div class="hero-frame hero-frame--primary" data-parallax data-parallax-speed="0.08">
          <img src={`${basePath}logo/aspire-logo-256.svg`} alt="" class="hero-frame__image hero-frame__image--primary" />
        </div>
      </div>
    </section>

    <section class="section section--accented section--about" id="about" data-reveal>
      <div class="section--split">
        <div>
          <SectionHeading
            anchorId="about"
            eyebrow="What&apos;s here"
            icon="layers"
            title="A focused brand kit for everyday use."
            description="Everything here is meant to help you move quickly without losing clarity: the official marks, the core colors, a stronger set of brand rules, and a current presentation deck."
          />

          <div class="note-card">
            <h3>Use this page for brand assets.</h3>
            <p>
              When you need product docs, deeper explanation, or supporting content, send people to{' '}
              <a href="https://aspire.dev" rel="noreferrer" target="_blank">aspire.dev</a>.
            </p>
          </div>
        </div>

        <ul class="feature-list" role="list">
          {featureHighlights.map((item) => (
            <li class="feature-list__item">
              <span class="feature-list__icon" aria-hidden="true">
                <Icon name={item.icon} size={18} />
              </span>
              <div class="feature-list__content">
                <h3>{item.title}</h3>
                <p>{item.description}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="section section--accented section--logos" id="logos" data-reveal>
      <SectionHeading
        anchorId="logos"
        eyebrow="Logos"
        icon="image"
        title="Use the official Aspire marks."
        description="Choose the size that best fits the space, then keep the shape and color relationships intact."
      />
      <div class="asset-grid">
        {logoAssets.map((logo) => (
          <article class="asset-card">
            <div class={`asset-card__preview ${logo.previewClass}`} aria-hidden="true">
              <img src={logo.asset} alt="" class={logo.assetClass} />
            </div>

            <div class="asset-card__body">
              <div class="stack">
                <h3>{logo.title}</h3>
                <p>{logo.description}</p>
              </div>

              <div class="link-row">
                {logo.downloads.map((download) => (
                  <a class="pill-link" href={download.href} download>
                    <Icon name={download.icon} size={16} />
                    <span>{download.label}</span>
                  </a>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section section--accented section--colors" id="colors" data-reveal>
      <SectionHeading
        anchorId="colors"
        eyebrow="Colors"
        icon="palette"
        title="Core Aspire colors."
        description="Use the core colors most often, then bring in accent colors and gradients when you need more expression without losing recognizability."
      />
      <div class="color-grid">
        {colorScale.map((color) => (
          <article class="color-card">
            <div class="swatch" style={`background:${color.hex}`}></div>
            <div class="stack">
              <h3>{color.name}</h3>
              <p>{color.description}</p>
            </div>
            <div class="color-card__footer">
              <div class="color-card__actions">
                <code class="color-card__hex">{color.hex}</code>
                <CopyButton value={color.hex} label="Copy" ariaLabel={`Copy ${color.hex}`} />
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="color-showcase">
        <div>
          <div class="section-subhead">
            <h3>Supporting accents</h3>
            <p>Use these sparingly for diagrams, highlights, editorial moments, or motion accents around the core palette.</p>
          </div>
          <ul class="accent-spectrum__list" role="list">
            {supportingAccents.map((accent) => (
              <li class="accent-chip">
                <span class="accent-chip__swatch" style={`background:${accent.hex}`}></span>
                <span class="accent-chip__name">{accent.name}</span>
                <code class="accent-chip__hex">{accent.hex}</code>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <div class="section-subhead">
            <h3>Supporting gradients</h3>
            <p>Use gradients as a controlled highlight. Let them add energy, but keep the surrounding layout calm and readable.</p>
          </div>
          <ul class="gradient-list" role="list">
            {gradients.map((gradient) => (
              <li class="gradient-band">
                <div class="gradient-band__swatch" aria-hidden="true" style={`background:${gradient.value}`}></div>
                <div class="gradient-band__body">
                  <h4>{gradient.name}</h4>
                  <p>{gradient.guidance}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="section section--accented section--css" id="css-vars" data-reveal>
      <SectionHeading
        anchorId="css-vars"
        eyebrow="CSS variables"
        icon="code"
        title="Ready-to-use color tokens."
        description="If you&apos;re styling a web experience or demo, start here and trim the block to the tokens you actually need."
      />
      <article class="code-card">
        <div class="code-card__header">
          <div class="stack">
            <h3>Aspire CSS variables</h3>
            <p>Use this as a clean starting point for implementation.</p>
          </div>
          <CopyButton value={cssVarBlock} label="Copy CSS vars" ariaLabel="Copy Aspire CSS variables" />
        </div>
        <Code code={cssVarBlock} lang="css" title="aspire-brand-tokens.css" />
      </article>
    </section>

    <section class="section section--accented section--guidance" id="guidance" data-reveal>
      <SectionHeading
        anchorId="guidance"
        eyebrow="Guidance"
        icon="compass"
        title="A few simple rules go a long way."
        description="The strongest brand systems communicate clearly: they protect the mark, keep the language precise, and let the experience feel approachable."
      />

      <div class="guidance-panels">
        <article class="guidance-panel guidance-panel--do">
          <div class="guidance-panel__header">
            <span class="guidance-panel__badge" aria-hidden="true">
              <Icon name="check-circle" size={18} />
            </span>
            <div class="stack">
              <h3>Do</h3>
              <p>Use the brand in ways that feel clear, helpful, and consistent wherever people encounter Aspire.</p>
            </div>
          </div>

          <ul class="guidance-list guidance-list--do" role="list">
            {guidanceDos.map((item) => (
              <li>
                <Icon name="check-circle" size={16} />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </article>

        <article class="guidance-panel guidance-panel--dont">
          <div class="guidance-panel__header">
            <span class="guidance-panel__badge" aria-hidden="true">
              <Icon name="x-circle" size={18} />
            </span>
            <div class="stack">
              <h3>Do not</h3>
              <p>Avoid the shortcuts and visual changes that make the brand feel less recognizable or less human.</p>
            </div>
          </div>

          <ul class="guidance-list guidance-list--dont" role="list">
            {guidanceDonts.map((item) => (
              <li>
                <Icon name="x-circle" size={16} />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </article>
      </div>
    </section>

    <section class="section section--accented section--slides" id="slides" data-reveal>
      <SectionHeading
        anchorId="slides"
        eyebrow="Presentation materials"
        icon="presentation"
        title="Start from the current deck."
        description="Use the latest deck as a starting point for talks, demos, and community sessions, then tailor it to the audience."
      />
      <article class="download-card">
        <div class="download-card__copy">
          <h3>Aspire Spring 2026 intro deck</h3>
          <p>
            Use the current deck as a starting point for talks, demos, and community sessions about Aspire.
          </p>
          <p class="download-card__meta">PowerPoint (.pptx)</p>
        </div>
        <div class="link-row">
          <a class="pill-link" href={deckPath} download>
            <Icon name="download" size={16} />
            <span>Download deck</span>
          </a>
        </div>
      </article>
    </section>

    <section class="section section--accented section--license" id="license" data-reveal>
      <SectionHeading
        anchorId="license"
        eyebrow="License"
        icon="shield"
        title="Use the artwork broadly. Respect the trademark."
        description="The artwork is open for reuse. The Aspire name and logo remain protected marks."
      />
      <article class="license-card">
        <p>
          The artwork in this brand kit is released under CC0 1.0 for broad reuse in decks, blog posts, and other
          Aspire-related content. Trademark rights are not waived; the Aspire name and logo remain subject to
          Microsoft&apos;s trademark rights and brand review expectations.
        </p>
        <div class="link-row">
          <a class="pill-link" href={repoUrl} rel="noreferrer" target="_blank">
            <Icon name="github" size={16} />
            <span>View on GitHub</span>
          </a>
        </div>
      </article>
    </section>
  </main>
</BrandLayout>
